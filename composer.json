{
    "name": "jeffersongoncalves/laravel-metrics-fathom",
    "description": "Laravel package to interact with Fathom Analytics API - fetch pageviews, visitors, events, and generate custom reports",
    "keywords": [
        "laravel",
        "fathom",
        "analytics",
        "metrics",
        "pageviews",
        "visitors",
        "privacy"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Jefferson Goncalves",
            "email": "jeffersondev@outlook.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.14.0",
        "spatie/laravel-settings": "^3.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.21",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "JeffersonGoncalves\\MetricsFathom\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JeffersonGoncalves\\MetricsFathom\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "test": "vendor/bin/pest"
    },
    "extra": {
        "laravel": {
            "providers": [
                "JeffersonGoncalves\\MetricsFathom\\FathomServiceProvider"
            ],
            "aliases": {
                "Fathom": "JeffersonGoncalves\\MetricsFathom\\Facades\\Fathom"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
